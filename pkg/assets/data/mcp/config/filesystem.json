{
  "$schema": "https://juarvis.ai/mcp.schema.json",
  "id": "filesystem",
  "name": "Filesystem MCP Server",
  "description": "Operaciones avanzadas de sistema de archivos con permisos controlados",
  "version": "1.0.0",
  "package": "@modelcontextprotocol/server-filesystem",
  "category": "development",
  "env_vars": [],
  "parameters": [
    {
      "name": "allowed_directories",
      "description": "Directorios permitidos para operaciones",
      "type": "array",
      "default": ["."]
    }
  ],
  "tools": [
    "read_file",
    "read_multiple_files",
    "write_file",
    "create_directory",
    "list_directory",
    "move_file",
    "delete_file",
    "search_files"
  ],
  "config": {
    "mcpServers": {
      "filesystem": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-filesystem", "."]
      }
    }
  },
  "security": {
    "allowed_paths": ["${PROJECT_ROOT}"],
    "denied_paths": [".git", "node_modules", "**/secrets/**"]
  }
}