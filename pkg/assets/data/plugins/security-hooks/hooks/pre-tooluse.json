{
  "$schema": "https://juarvis.ai/hook.schema.json",
  "version": "1.0",
  "name": "pre-tooluse-security",
  "description": "Hooks de seguridad PreToolUse - se ejecutan ANTES de cada herramienta",
  "hooks": [
    {
      "name": "block-rm-rf",
      "description": "Bloquea comandos rm -rf peligrosos",
      "event": "PreToolUse",
      "matcher": "Bash(rm -rf",
      "action": "deny",
      "reason": "Comando de eliminación recursiva potencialmente peligroso"
    },
    {
      "name": "block-fork-bomb",
      "description": "Bloquea fork bombs y ataques DoS",
      "event": "PreToolUse", 
      "matcher": "Bash(:\\(\\)|Bash(fork|Bash(while.*do",
      "action": "deny",
      "reason": "Potencial fork bomb o bucle infinito"
    },
    {
      "name": "block-system-commands",
      "description": "Bloquea comandos de sistema peligrosos",
      "event": "PreToolUse",
      "matcher": "Bash(shutdown|Bash(reboot|Bash(halt|Bash(mkfs|Bash(dd if=",
      "action": "deny",
      "reason": "Comando de bajo nivel del sistema"
    },
    {
      "name": "block-sudo-commands",
      "description": "Requiere confirmación para sudo",
      "event": "PreToolUse",
      "matcher": "Bash(sudo",
      "action": "ask",
      "reason": "Comando con privilegios de root"
    },
    {
      "name": "prevent-secrets",
      "description": "Previene escribir secrets en código",
      "event": "PreToolUse",
      "matcher": "Write|Edit",
      "conditions": [
        {
          "field": "new_text",
          "operator": "regex_match",
          "pattern": "(password|api_key|secret|token|apikey|auth_token|private_key)\\s*[:=]"
        }
      ],
      "action": "deny",
      "reason": "No escribir secrets directamente en código"
    },
    {
      "name": "validate-package-json",
      "description": "Valida package.json antes de npm install",
      "event": "PreToolUse",
      "matcher": "Bash(npm install|Bash(yarn add|Bash(pnpm add",
      "action": "warn",
      "reason": "Instalando dependencias - verificar package.json"
    },
    {
      "name": "auto-snapshot",
      "description": "Crea snapshot automático antes de Write/Edit",
      "event": "PreToolUse",
      "matcher": "Write|Edit",
      "action": "command",
      "command": ["juarvis", "snapshot", "auto-create"],
      "fallback": "warn"
    },
    {
      "name": "check-git-push",
      "description": "Valida antes de git push",
      "event": "PreToolUse",
      "matcher": "Bash(git push",
      "action": "ask",
      "reason": "Confirmar antes de hacer push al remoto"
    },
    {
      "name": "force-push-warning",
      "description": "Warn sobre force push",
      "event": "PreToolUse",
      "matcher": "Bash(git push.*force|Bash(git push -f",
      "action": "deny",
      "reason": "Force push deshabilitado por seguridad"
    }
  ]
}